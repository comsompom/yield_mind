# YieldMind — copy to .env and fill in
# See README "Initia Hackathon Setup" for Weave, Gas Station, and faucet.

SECRET_KEY=change-me-in-production
FLASK_DEBUG=0

# Initia L1 Testnet (no API key). After launching your rollup, use your rollup RPC + chain ID here.
INITIA_RPC_URL=https://rpc.testnet.initia.xyz
CHAIN_ID=initiation-2

# Optional: your rollup (e.g. after "weave init" with chain ID yieldmind-1)
# INITIA_RPC_URL=http://localhost:26657
# CHAIN_ID=yieldmind-1

# AI recommendations (OpenAI key — not from Initia)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
FEE_RATE=0.002
FEE_RECIPIENT=
